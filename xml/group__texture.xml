        <type>std::shared_ptr&lt; FrameBuffer &gt;</type>
        <definition>std::shared_ptr&lt; FrameBuffer &gt; eu::render::build_msaa_framebuffer</definition>
        <argsstring>(DEBUG_LABEL_ARG_MANY const Size &amp;size, int msaa_samples, ColorBitsPerPixel bits_per_pixel)</argsstring>
        <name>build_msaa_framebuffer</name>
        <qualifiedname>eu::render::build_msaa_framebuffer</qualifiedname>
