    <sectiondef kind="define">
      <memberdef kind="define" id="group__hash_1ga9038dc1dac99b31ae58ae04bee68d416" prot="public" static="no">
        <name>HASH_DEF_BEGIN</name>
        <param><defname>TYPE</defname></param>
        <initializer>	template&lt;&gt; \
	struct std::hash&lt;TYPE&gt; \
	{ \
		std::size_t operator()(const TYPE&amp; x) const \
		{ \
			return <ref refid="structeu_1_1core_1_1HashCombiner" kindref="compound">eu::core::HashCombiner</ref> \
			{ \
			}</initializer>
        <briefdescription>
<para>Begins the definition of a specialization of std::hash for the given TYPE. </para>
        </briefdescription>
        <detaileddescription>
<para>Should be closed by the <ref refid="group__hash_1gadea525dabdf353ba96abce59e6a5dadd" kindref="member">HASH_DEF_END</ref> macro <parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername>TYPE</parametername>
</parameternamelist>
